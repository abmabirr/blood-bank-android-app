<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="30dp">

        <ImageView
            android:id="@+id/detailBackBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/colorPrimary"
            android:padding="4dp"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Request Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/detailBlood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blood Required: A+"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/bloody_red"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/detailLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Location: Dhaka Medical"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/detailPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 Phone: 01700000000"
                android:textSize="18sp"
                android:textColor="#1976D2"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Message:"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/detailMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Emergency blood needed for surgery. Please help."
                android:textSize="16sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/detailTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Posted: 10 mins ago"
                android:textSize="12sp"
                android:textColor="@color/gray_dark"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/detailCallBtn"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="CALL"
                    app:icon="@android:drawable/stat_sys_phone_call"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="#1976D2"
                    app:cornerRadius="15dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/detailDoneBtn"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="DONATED"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="#388E3C"
                    app:cornerRadius="15dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/detailDeleteBtn"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="DELETE REQUEST (ADMIN)"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="#D32F2F"
                app:cornerRadius="15dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
